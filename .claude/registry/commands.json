{
  "source": ".claude/skills/*/SKILL.md",
  "canonical_commands": ["plan", "debug", "review", "audit", "monitor"],
  "commands": [
    {
      "name": "plan",
      "status": "active",
      "default_mode": "interactive",
      "intent": "Create structured implementation plans with specs",
      "entry_file": ".claude/skills/plan/SKILL.md",
      "owned_skills": ["plan"]
    },
    {
      "name": "debug",
      "status": "active",
      "default_mode": "interactive",
      "intent": "Root cause investigation and systematic debugging",
      "entry_file": ".claude/skills/debug/SKILL.md",
      "owned_skills": ["debug", "tdd-bugfix"]
    },
    {
      "name": "review",
      "status": "active",
      "default_mode": "interactive",
      "intent": "6-pass systematic code review with structured findings",
      "entry_file": ".claude/skills/review/SKILL.md",
      "owned_skills": ["review", "autonomous-review", "cross-package-verify"]
    },
    {
      "name": "audit",
      "status": "active",
      "default_mode": "interactive",
      "intent": "Dead code detection and architectural anti-pattern analysis",
      "entry_file": ".claude/skills/audit/SKILL.md",
      "owned_skills": ["audit"]
    },
    {
      "name": "monitor",
      "status": "active",
      "default_mode": "interactive",
      "intent": "Quality gate and regression monitor — one-shot or continuous with /loop",
      "entry_file": ".claude/skills/monitor/SKILL.md",
      "owned_skills": ["monitor"]
    }
  ],
  "aliases": {
    "cross-package-verify": "/review --mode verify_only --scope cross-package",
    "autonomous review": "/review --mode apply_fixes",
    "tdd bugfix": "/debug --mode tdd_bugfix",
    "guard": "/monitor",
    "watch-tests": "/monitor --tests",
    "watch-build": "/monitor --build"
  }
}
