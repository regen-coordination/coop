  "decisions": [
    {
      "id": "D1",
      "choice": "Separate feature pack from agent-autonomy-onchain",
      "rationale": "Session expansion crosses repos and has own acceptance criteria"
    },
    {
      "id": "D2",
      "choice": "Five phases: expand → lifecycle → Hats → yield → cockpit",
      "rationale": "Each independently shippable; later depends on earlier"
    },
    {
      "id": "D3",
      "choice": "Member-account actions stay out of session scope",
      "rationale": "Member actions need per-user Kernel signatures, not coop-level delegation"
    },
    {
      "id": "D5",
      "choice": "Auto-rotation at 80% of maxUses, not after exhaustion",
      "rationale": "Graceful migration avoids failed executions at usage limit"
    },
    {
      "id": "D6",
      "choice": "TDD red-green-refactor per phase",
      "rationale": "Existing test factories are extensible; failing tests first"
    },
    {
      "id": "D8",
      "choice": "Backwards compatibility required for all schema changes",
      "rationale": "Existing capabilities must keep working with sensible defaults"
    }
  ],
