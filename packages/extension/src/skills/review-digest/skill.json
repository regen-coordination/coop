{
  "id": "review-digest",
  "version": "0.1.0",
  "description": "Produce a weekly-style synthesis draft from accepted drafts and recent shared artifacts.",
  "runtime": "extension-offscreen",
  "model": "webllm",
  "triggers": ["ritual-review-due"],
  "inputSchemaRef": "agent-observation",
  "outputSchemaRef": "review-digest-output",
  "allowedTools": [
    "read-coop-context",
    "list-related-artifacts",
    "list-related-drafts",
    "create-review-draft"
  ],
  "allowedActionClasses": [],
  "requiredCapabilities": ["coop-context"],
  "approvalMode": "advisory",
  "timeoutMs": 45000,
  "maxTokens": 700,
  "qualityProfile": "synthesis-v1",
  "qualityThreshold": 0.72,
  "maxEvaluatorRetries": 1,
  "depends": [],
  "provides": ["drafts"]
}
