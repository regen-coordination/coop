{
  "installCommand": "cd ../.. && bun install",
  "buildCommand": "bun run vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/pair", "destination": "/index.html" },
    { "source": "/receiver", "destination": "/index.html" },
    { "source": "/inbox", "destination": "/index.html" },
    { "source": "/board/:path*", "destination": "/index.html" }
  ]
}
