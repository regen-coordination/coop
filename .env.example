# Coop Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# ANCHOR NODE CONFIGURATION
# =============================================================================

# Port for the main Anchor API (REST)
COOP_ANCHOR_PORT=8787

# Port for WebSocket relay server
COOP_ANCHOR_WS_PORT=8788

# =============================================================================
# AI INFERENCE (Anthropic)
# =============================================================================

# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model to use for inference (defaults to claude-3-5-sonnet-latest)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# =============================================================================
# COLD STORAGE (Storacha / Filecoin)
# =============================================================================

# Storacha private key (generate with: npx ucan-key ed --json)
STORACHA_KEY=...

# Delegation proof (base64-encoded CAR file)
STORACHA_PROOF=...

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path (defaults to ./data/coop.db)
# DATABASE_URL=./data/coop.db

# =============================================================================
# BLOCKCHAIN (Optional - for on-chain registry)
# =============================================================================

# Ethereum RPC URL (e.g., Infura, Alchemy, or local node)
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Private key for contract interactions (keep secure!)
# PRIVATE_KEY=0x...

# CoopRegistry contract address (if deployed)
# COOP_REGISTRY_ADDRESS=0x...

# Chain ID (1=mainnet, 137=polygon, 42161=arbitrum, etc.)
# CHAIN_ID=1

# =============================================================================
# EXTENSION CONFIGURATION (for development)
# =============================================================================

# Extension ID (for CORS allowlist - get from chrome://extensions)
# EXTENSION_ID=...

# =============================================================================
# PWA CONFIGURATION
# =============================================================================

# VAPID keys for push notifications (generate with web-push)
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@yourcoop.org

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable debug logging
# DEBUG=coop:*

# Disable AI inference (use fallback mode)
# DISABLE_AI_INFERENCE=true

# Mock storage uploads (no real Storacha calls)
# MOCK_STORAGE=true
