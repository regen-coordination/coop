{
  "name": "coop",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bunx concurrently -n app,extension \"bun run --filter @coop/app dev\" \"bun run --filter @coop/extension dev\"",
    "dev:app": "bun run --filter @coop/app dev",
    "dev:extension": "bun run --filter @coop/extension dev",
    "dev:signaling": "node ./scripts/y-webrtc-signaling.mjs",
    "build": "bun run --filter @coop/shared build && bun run --filter @coop/app build && bun run --filter @coop/extension build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.325",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8",
    "ws": "^8.19.0"
  }
}
